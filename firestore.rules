rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && (
          request.auth.token.admin == true
          || request.auth.token.role == 'admin'
          || exists(/databases/$(database)/documents/adminRoles/$(request.auth.uid))
        );
    }

    function isShortText(value, max) {
      return value is string && value.size() > 0 && value.size() <= max;
    }

    function isOptionalText(value, max) {
      return !('value' in request.resource.data) || value == null || (value is string && value.size() <= max);
    }

    function validStatus() {
      return request.resource.data.status in ['new', 'processed', 'accepted', 'rejected'];
    }

    function validApplication() {
      return request.resource.data.keys().hasOnly(['fullName', 'phone', 'program', 'message', 'status', 'createdAt'])
        && isShortText(request.resource.data.fullName, 120)
        && isShortText(request.resource.data.phone, 40)
        && isShortText(request.resource.data.program, 120)
        && (!('message' in request.resource.data) || request.resource.data.message is string && request.resource.data.message.size() <= 1000)
        && request.resource.data.status == 'new'
        && request.resource.data.createdAt == request.time;
    }

    function validInquiry() {
      return request.resource.data.keys().hasOnly(['name', 'phone', 'subject', 'message', 'type', 'status', 'createdAt'])
        && isShortText(request.resource.data.name, 120)
        && isShortText(request.resource.data.phone, 40)
        && isShortText(request.resource.data.subject, 120)
        && isShortText(request.resource.data.message, 1200)
        && (!('type' in request.resource.data) || request.resource.data.type is string && request.resource.data.type.size() <= 60)
        && request.resource.data.status == 'new'
        && request.resource.data.createdAt == request.time;
    }

    match /adminRoles/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    match /news/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /programs/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /content/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /assistantFaq/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /applications/{document} {
      allow create: if validApplication();
      allow read, update, delete: if isAdmin();
    }

    match /inquiries/{document} {
      allow create: if validInquiry();
      allow read, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
