rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function adminRolePath() {
      return /databases/$(database)/documents/adminRoles/$(request.auth.uid);
    }

    function hasAdminRoleDoc() {
      return signedIn()
        && exists(adminRolePath())
        && get(adminRolePath()).data.role == 'admin';
    }

    function isAdmin() {
      return signedIn()
        && (
          request.auth.token.admin == true
          || request.auth.token.role == 'admin'
          || hasAdminRoleDoc()
        );
    }

    function isShortText(value, max) {
      return value is string && value.size() > 0 && value.size() <= max;
    }

    function isOptionalText(value, max) {
      return value == null || (value is string && value.size() <= max);
    }

    function validStatus(value) {
      return value in ['new', 'viewed', 'contacted', 'processed', 'completed', 'accepted', 'rejected'];
    }

    function validApplicationCreate() {
      return request.resource.data.keys().hasOnly(['fullName', 'phone', 'program', 'message', 'status', 'createdAt', 'source', 'isRead'])
        && isShortText(request.resource.data.fullName, 120)
        && isShortText(request.resource.data.phone, 40)
        && isShortText(request.resource.data.program, 120)
        && (!('message' in request.resource.data) || isOptionalText(request.resource.data.message, 1000))
        && request.resource.data.status == 'new'
        && (!('source' in request.resource.data) || request.resource.data.source == 'website')
        && (!('isRead' in request.resource.data) || request.resource.data.isRead == false)
        && request.resource.data.createdAt == request.time;
    }

    function validInquiryCreate() {
      return request.resource.data.keys().hasOnly(['name', 'phone', 'subject', 'message', 'type', 'status', 'createdAt', 'source', 'isRead'])
        && isShortText(request.resource.data.name, 120)
        && isShortText(request.resource.data.phone, 40)
        && isShortText(request.resource.data.subject, 120)
        && isShortText(request.resource.data.message, 1200)
        && (!('type' in request.resource.data) || isOptionalText(request.resource.data.type, 60))
        && request.resource.data.status == 'new'
        && (!('source' in request.resource.data) || request.resource.data.source == 'website')
        && (!('isRead' in request.resource.data) || request.resource.data.isRead == false)
        && request.resource.data.createdAt == request.time;
    }

    function validNewsWrite() {
      return request.resource.data.keys().hasOnly(['title', 'category', 'image', 'excerpt', 'content', 'date', 'deleted', 'createdAt', 'updatedAt'])
        && (!('title' in request.resource.data) || isOptionalText(request.resource.data.title, 180))
        && (!('category' in request.resource.data) || isOptionalText(request.resource.data.category, 80))
        && (!('image' in request.resource.data) || isOptionalText(request.resource.data.image, 500))
        && (!('excerpt' in request.resource.data) || isOptionalText(request.resource.data.excerpt, 500))
        && (!('content' in request.resource.data) || isOptionalText(request.resource.data.content, 6000))
        && (!('date' in request.resource.data) || isOptionalText(request.resource.data.date, 80))
        && (!('deleted' in request.resource.data) || request.resource.data.deleted is bool);
    }

    function validProgramWrite() {
      return request.resource.data.keys().hasOnly(['title', 'duration', 'format', 'subjects', 'opportunities', 'outcomes', 'structure', 'books', 'image', 'desc', 'fullDesc', 'order', 'deleted', 'createdAt', 'updatedAt'])
        && (!('title' in request.resource.data) || isOptionalText(request.resource.data.title, 180))
        && (!('duration' in request.resource.data) || isOptionalText(request.resource.data.duration, 80))
        && (!('format' in request.resource.data) || isOptionalText(request.resource.data.format, 160))
        && (!('image' in request.resource.data) || isOptionalText(request.resource.data.image, 500))
        && (!('desc' in request.resource.data) || isOptionalText(request.resource.data.desc, 1600))
        && (!('fullDesc' in request.resource.data) || isOptionalText(request.resource.data.fullDesc, 4000))
        && (!('order' in request.resource.data) || request.resource.data.order is int || request.resource.data.order is float || request.resource.data.order is string)
        && (!('deleted' in request.resource.data) || request.resource.data.deleted is bool);
    }

    function validGalleryWrite() {
      return request.resource.data.keys().hasOnly(['title', 'category', 'image', 'description', 'deleted', 'createdAt', 'updatedAt'])
        && (!('title' in request.resource.data) || isOptionalText(request.resource.data.title, 160))
        && (!('category' in request.resource.data) || isOptionalText(request.resource.data.category, 80))
        && (!('image' in request.resource.data) || isOptionalText(request.resource.data.image, 500))
        && (!('description' in request.resource.data) || isOptionalText(request.resource.data.description, 1000))
        && (!('deleted' in request.resource.data) || request.resource.data.deleted is bool);
    }

    function validAssistantFaqWrite() {
      return request.resource.data.keys().hasOnly(['question', 'answer', 'language', 'deleted', 'createdAt', 'updatedAt'])
        && (!('question' in request.resource.data) || isOptionalText(request.resource.data.question, 220))
        && (!('answer' in request.resource.data) || isOptionalText(request.resource.data.answer, 1600))
        && (!('language' in request.resource.data) || request.resource.data.language in ['kz', 'ru', 'en', 'ar'])
        && (!('deleted' in request.resource.data) || request.resource.data.deleted is bool);
    }

    match /adminRoles/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create, update: if isAdmin()
        && request.resource.data.keys().hasOnly(['role', 'email', 'createdAt', 'updatedAt'])
        && request.resource.data.role == 'admin';
      allow delete: if isAdmin();
    }

    match /news/{document} {
      allow read: if true;
      allow create, update: if isAdmin() && validNewsWrite();
      allow delete: if isAdmin();
    }

    match /programs/{document} {
      allow read: if true;
      allow create, update: if isAdmin() && validProgramWrite();
      allow delete: if isAdmin();
    }

    match /gallery/{document} {
      allow read: if true;
      allow create, update: if isAdmin() && validGalleryWrite();
      allow delete: if isAdmin();
    }

    match /assistantFaq/{document} {
      allow read: if true;
      allow create, update: if isAdmin() && validAssistantFaqWrite();
      allow delete: if isAdmin();
    }

    match /adminUsers/{uid}/notificationReads/{document} {
      allow read, delete: if isAdmin() && request.auth.uid == uid;
      allow create, update: if isAdmin() && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['read', 'updatedAt'])
        && (!('read' in request.resource.data) || request.resource.data.read is bool);
    }

    match /adminUsers/{uid}/notificationTokens/{document} {
      allow read, delete: if isAdmin() && request.auth.uid == uid;
      allow create, update: if isAdmin() && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['token', 'uid', 'email', 'userAgent', 'enabled', 'createdAt', 'updatedAt'])
        && request.resource.data.uid == uid
        && (!('token' in request.resource.data) || isShortText(request.resource.data.token, 300))
        && (!('email' in request.resource.data) || isOptionalText(request.resource.data.email, 180))
        && (!('userAgent' in request.resource.data) || isOptionalText(request.resource.data.userAgent, 500))
        && (!('enabled' in request.resource.data) || request.resource.data.enabled is bool);
    }

    match /siteTexts/{document} {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.data.keys().hasOnly(['key', 'language', 'value', 'deleted', 'createdAt', 'updatedAt'])
        && (!('key' in request.resource.data) || isOptionalText(request.resource.data.key, 120))
        && (!('language' in request.resource.data) || request.resource.data.language in ['kz', 'ru', 'en', 'ar'])
        && (!('value' in request.resource.data) || isOptionalText(request.resource.data.value, 4000));
      allow delete: if isAdmin();
    }

    match /applications/{document} {
      allow create: if validApplicationCreate();
      allow read, delete: if isAdmin();
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'archived'])
        && (!request.resource.data.diff(resource.data).changedKeys().hasAny(['status']) || validStatus(request.resource.data.status))
        && (!request.resource.data.diff(resource.data).changedKeys().hasAny(['archived']) || request.resource.data.archived is bool);
    }

    match /inquiries/{document} {
      allow create: if validInquiryCreate();
      allow read, delete: if isAdmin();
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'archived'])
        && (!request.resource.data.diff(resource.data).changedKeys().hasAny(['status']) || validStatus(request.resource.data.status))
        && (!request.resource.data.diff(resource.data).changedKeys().hasAny(['archived']) || request.resource.data.archived is bool);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
