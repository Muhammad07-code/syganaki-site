rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function hasAdminRoleDoc() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/adminRoles/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/adminRoles/$(request.auth.uid)).data.role == 'admin';
    }

    function isAdmin() {
      return signedIn()
        && (
          request.auth.token.admin == true
          || request.auth.token.role == 'admin'
          || hasAdminRoleDoc()
        );
    }

    function safeFileName(fileName) {
      return fileName.matches('^[A-Za-z0-9._-]+$');
    }

    function validImage(fileName) {
      return request.resource != null
        && safeFileName(fileName)
        && request.resource.size > 0
        && request.resource.size < 3 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    match /news/{fileName} {
      allow read: if true;
      allow create, update: if isAdmin() && validImage(fileName);
      allow delete: if isAdmin();
    }

    match /gallery/{fileName} {
      allow read: if true;
      allow create, update: if isAdmin() && validImage(fileName);
      allow delete: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
